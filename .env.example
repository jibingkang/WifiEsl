# ==========================================
# WifiEsl Docker 部署环境变量配置
# 复制此文件为 .env 并修改配置
# ==========================================

# JWT 密钥（生产环境必须修改！）
SECRET_KEY=your-super-secret-key-change-this

# 管理员账号
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-password

# WIFI 系统配置（根据实际环境填写）
WIFI_BASE_URL=http://your-wifi-system-ip:8080
WIFI_API_KEY=your-wifi-api-key
